# JWT Configuration
JWT_SECRET=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Database
DATABASE_URL=postgresql://sprintboard:password@localhost:5433/sprintboard

# Slack Integration (Optional)
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_DEFAULT_CHANNEL=task-updates
SLACK_NOTIFICATION_MODE=channel  # or 'dm' for direct messages

# Server
ENVIRONMENT=development  # or 'production'
DEBUG=False
